pretrained/
*.pt
*.pkl
*.dat
*.npy

# --- Comprimidos ---
*.zip

# --- Salidas que el backend genera en runtime ---
backend/storage/

# --- Logs de decisiones de la app ---
logs/

# --- Imágenes de prueba generadas ---
inference_test.png
reconstruccion.png

# --- Estado/config local de Claude Code y directorio basura ---
.claude/
{src,configs,scripts,docs}/

